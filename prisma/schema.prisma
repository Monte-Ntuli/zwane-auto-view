generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Vehicle {
  id           String   @id @default(uuid())
  make         String
  model        String
  year         Int
  price        Float
  mileage      Int
  fuelType     String
  transmission String
  color        String?
  engine       String?
  description  String?
  status       String   @default("available")
  featured     Boolean  @default(false)
  images       Image[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Image {
  id        String  @id @default(uuid())
  url       String
  isPrimary Boolean @default(false)
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId String
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}
